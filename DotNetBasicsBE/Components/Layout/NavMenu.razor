@inject DotNetBasicsBE.Application.AppStateService AppState

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">DotNetBasics</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> @AppState.T("Start", "Home")
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="cars">
                <span class="bi bi-car-nav-menu" aria-hidden="true"></span> @AppState.T("Samochody", "Cars")
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="learn">
                <span class="bi bi-mortarboard-nav-menu" aria-hidden="true"></span> Learn
            </NavLink>
        </div>
    </nav>
</div>

