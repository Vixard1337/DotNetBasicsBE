@inject DotNetBasicsBE.Application.EducationalSandboxService Sandbox
@inject DotNetBasicsBE.Application.AppStateService AppState

<div class="card h-100">
    <div class="card-body">
        <h5 class="card-title">OOP: Inheritance & Polymorphism</h5>
        <p class="card-text">Car inherits from Vehicle and overrides behavior using polymorphism.</p>
        <pre><code>Vehicle vehicle = new Car { Brand = "Toyota", Model = "Corolla", Year = 2022 };
string result = vehicle.GetDescription();</code></pre>
        <button class="btn btn-outline-primary" @onclick="RunDemo">Try it out</button>
        @if (!string.IsNullOrWhiteSpace(_result))
        {
            <p class="mt-3 mb-0"><strong>Result:</strong> @_result</p>
        }
    </div>
</div>

@code {
    private string? _result;

    private void RunDemo()
    {
        _result = Sandbox.RunOopDemo();
        AppState.AddLog("OOP module executed.");
    }
}
