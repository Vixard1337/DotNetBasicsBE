@inject DotNetBasicsBE.Application.EducationalSandboxService Sandbox
@inject DotNetBasicsBE.Application.ICarService CarService
@inject DotNetBasicsBE.Application.AppStateService AppState

<div class="card h-100">
    <div class="card-body">
        <h5 class="card-title">LINQ</h5>
        <p class="card-text">Filters cars from 2020+ and sorts results by brand and model.</p>
        <pre><code>cars.Where(c =&gt; c.Year &gt;= 2020)
    .OrderBy(c =&gt; c.Brand)
    .ThenBy(c =&gt; c.Model);</code></pre>
        <button class="btn btn-outline-primary" @onclick="RunDemoAsync">Try it out</button>
        @if (!string.IsNullOrWhiteSpace(_result))
        {
            <p class="mt-3 mb-0"><strong>Result:</strong> @_result</p>
        }
    </div>
</div>

@code {
    private string? _result;

    private async Task RunDemoAsync()
    {
        var cars = await CarService.GetAllAsync();
        _result = Sandbox.RunLinqDemo(cars);
        AppState.AddLog("LINQ module executed.");
    }
}
