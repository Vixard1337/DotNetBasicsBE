@inject DotNetBasicsBE.Application.EducationalSandboxService Sandbox
@inject DotNetBasicsBE.Application.ICarService CarService
@inject DotNetBasicsBE.Application.AppStateService AppState

<div class="card h-100">
    <div class="card-body">
        <h5 class="card-title">Dependency Injection</h5>
        <p class="card-text">Shows how services are resolved from the built-in DI container.</p>
        <pre><code>builder.Services.AddScoped&lt;ICarService, CarService&gt;();
var result = sandbox.RunDiDemo(carService);</code></pre>
        <button class="btn btn-outline-primary" @onclick="RunDemo">Try it out</button>
        @if (!string.IsNullOrWhiteSpace(_result))
        {
            <p class="mt-3 mb-0"><strong>Result:</strong> @_result</p>
        }
    </div>
</div>

@code {
    private string? _result;

    private void RunDemo()
    {
        _result = Sandbox.RunDiDemo(CarService);
        AppState.AddLog("Dependency Injection module executed.");
    }
}
