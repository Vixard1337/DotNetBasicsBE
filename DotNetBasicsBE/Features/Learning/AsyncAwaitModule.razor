@inject DotNetBasicsBE.Application.EducationalSandboxService Sandbox
@inject DotNetBasicsBE.Application.AppStateService AppState

<div class="card h-100">
    <div class="card-body">
        <h5 class="card-title">async/await</h5>
        <p class="card-text">Demonstrates non-blocking asynchronous operations in .NET.</p>
        <pre><code>await Task.Delay(1000);
return "Async operation finished";</code></pre>
        <button class="btn btn-outline-primary" @onclick="RunDemoAsync" disabled="@_isRunning">Try it out</button>
        @if (_isRunning)
        {
            <p class="mt-3 mb-0 text-muted">Running async operation...</p>
        }
        else if (!string.IsNullOrWhiteSpace(_result))
        {
            <p class="mt-3 mb-0"><strong>Result:</strong> @_result</p>
        }
    </div>
</div>

@code {
    private bool _isRunning;
    private string? _result;

    private async Task RunDemoAsync()
    {
        _isRunning = true;
        _result = null;

        _result = await Sandbox.RunAsyncAwaitDemo();

        _isRunning = false;
        AppState.AddLog("async/await module executed.");
    }
}
